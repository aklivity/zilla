property networkAcceptWindow 8192

accept "zilla://streams/net0"
  option zilla:window ${networkAcceptWindow}
  option zilla:transmission "duplex"
  option zilla:byteorder "network"

accepted

connected

read  15                                # size
      18s                               # api_versions
      0s                                # v0
      (int:apiVersionsRequestId)
      5s "zilla"                        # client id

write 16                                 # size
      ${apiVersionsRequestId}
      0s                                 # error code
      1                                  # api key count
        36s                              # sasl authenticate
        0s                               # min version
        1s                               # max version

read  37                                # size
      36s                               # sasl.authenticate
      1s                                # v1
      (int:newRequestId)
      5s "zilla"                        # client id
      18
      [0x00] "username"                 # authentication bytes
      [0x00] "password"

write 20                                 # size
      ${newRequestId}
      0s                                 # error code
      -1s                                # error message
      -1                                 # authentication bytes
      0L                                 # session lifetime
