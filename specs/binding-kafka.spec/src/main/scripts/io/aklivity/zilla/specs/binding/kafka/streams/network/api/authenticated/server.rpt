property networkAcceptWindow 8192

accept "zilla://streams/net0"
  option zilla:window ${networkAcceptWindow}
  option zilla:transmission "duplex"
  option zilla:byteorder "network"

accepted

connected

read  15                                # size
      18s                               # api_versions
      0s                                # v0
      (int:apiVersionsRequestId)
      5s "zilla"                        # client id

write 28                                 # size
      ${apiVersionsRequestId}
      0s                                 # error code
      3                                  # api key count
        19s                              # create topics
        0s                               # min version
        7s                               # max version
        17s                              # sasl handshake
        0s                               # min version
        1s                               # max version
        36s                              # sasl authenticate
        0s                               # min version
        1s                               # max version

read  22                                # size
      17s                               # sasl.handshake
      1s                                # v1
      (int:saslHandshakeRequestId)
      5s "zilla"                        # client id
      5s "PLAIN"                        # mechanism

write 17                                 # size
      ${saslHandshakeRequestId}
      0s                                 # error code
      1                                  # mechanisms
        5s "PLAIN"                       # PLAIN

read  37                                # size
      36s                               # sasl.authenticate
      1s                                # v1
      (int:saslAuthenticateRequestId)
      5s "zilla"                        # client id
      18
      [0x00] "username"                 # authentication bytes
      [0x00] "password"

write 20                                 # size
      ${saslAuthenticateRequestId}
      0s                                 # error code
      -1s                                # error message
      -1                                 # authentication bytes
      0L                                 # session lifetime

read 144                                # size
      19s                               # create topics
      3s                                # v3
      (int:newRequestId)
      5s "zilla"                        # client id
      2                                 # topic count
        6s "events"                     # name
        1                               # number of partitions
        1s                              # replication factor
        1                               # assignments
            0                           # partition index
            1                           # broker ids
                0                       # broker id
        1                               # configs
            14s "cleanup.policy"        # name
            6s "delete"                 # value
        9s "snapshots"                  # name
        1                               # number of partitions
        1s                              # replication factor
        1                               # assignments
            0                           # partition index
            1                           # broker ids
                0                       # broker id
        1                               # configs
            14s "cleanup.policy"        # name
            7s "compact"                # value
      0                                 # timeout
      [0x00]                           # validateOnly

write 39                                 # size
      ${newRequestId}
      0                                  # throttle time ms
      2                                  # topics
        6s "events"                      # name
        0s                               # error code
        -1s                              # error message
        9s "snapshots"                   # name
        0s                               # error code
        -1s                              # error message
