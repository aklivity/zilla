connect "zilla://streams/app0"
    option zilla:window 8192
    option zilla:transmission "half-duplex"

write zilla:begin.ext ${kafka:beginEx()
                               .typeId(zilla:id("kafka"))
                               .apiRequest()
                                 .length(129)
                                 .api(19)
                                 .version(3)
                                 .clientId("zilla")
                                 .build()
                                .build()}

connected

write advised zilla:challenge ${kafka:matchChallengeEx()
                                  .typeId(zilla:id("kafka"))
                                  .apiChallenge()
                                      .versions(0, 2)
                                      .build()
                                  .build()}

write advise zilla:flush ${kafka:flushEx()
                              .typeId(zilla:id("kafka"))
                              .apiFlush()
                                  .version(3)
                                  .build()
                              .build()}

read zilla:reset.ext ${kafka:matchResetEx()
                                    .typeId(zilla:id("kafka"))
                                    .error(35)
                                    .build()}

write aborted
