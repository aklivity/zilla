property networkAcceptWindow 8192

accept "zilla://streams/net0"
  option zilla:window ${networkAcceptWindow}
  option zilla:transmission "duplex"
  option zilla:byteorder "network"

accepted

connected

read 22                                 # size
     17s                                # sasl.handshake
     1s                                 # v1
     (int:requestId)
     5s "zilla"                         # client id
     5s "PLAIN"                         # mechanism

write 10                                # size
      ${requestId}
      33s                               # unsupported sasl mechanism
      0                                 # mechanisms count (empty)
