[
    {
        "op": "add",
        "path": "/$defs/binding/properties/type/enum/-",
        "value": "mcp_schema_registry"
    },
    {
        "op": "add",
        "path": "/$defs/binding/allOf/-",
        "value":
        {
            "if":
            {
               "properties":
                {
                    "type":
                    {
                        "const": "mcp_schema_registry"
                    }
                }
            },
            "then":
            {
                "properties":
                {
                    "type":
                    {
                        "const": "mcp_schema_registry"
                    },
                    "kind":
                    {
                        "enum": [ "proxy" ]
                    },
                    "routes":
                    {
                        "items":
                        {
                            "properties":
                            {
                                "when":
                                {
                                    "items":
                                    {
                                        "properties":
                                        {
                                            "tool":
                                            {
                                                "title": "Tool Name",
                                                "type": "string",
                                                "enum": [
                                                    "list_subjects",
                                                    "describe_subject",
                                                    "get_schema",
                                                    "register_schema",
                                                    "delete_subject",
                                                    "delete_schema_version",
                                                    "check_compatibility",
                                                    "get_compatibility",
                                                    "set_compatibility",
                                                    "list_contexts"
                                                ]
                                            }
                                        },
                                        "additionalProperties": false
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
]
