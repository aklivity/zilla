accept "http://localhost:8080/compatibility/subjects/orders-value/versions/1"

accepted
connected

read http:method "POST"
read http:header "content-type" "application/json"

read '{"schemaType":"AVRO","schema":"\\"string\\""}'
read closed

write http:status "200" "OK"
write http:header "content-type" "application/json"
write http:content-length

write '{"is_compatible":true}'

write close
