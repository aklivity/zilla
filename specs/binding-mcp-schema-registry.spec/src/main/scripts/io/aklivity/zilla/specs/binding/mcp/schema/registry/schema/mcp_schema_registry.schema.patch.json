[
    {
        "op": "add",
        "path": "/$defs/binding/properties/type/enum/-",
        "value": "mcp_schema_registry"
    },
    {
        "op": "add",
        "path": "/$defs/binding/allOf/-",
        "value":
        {
            "if":
            {
                "properties":
                {
                    "type":
                    {
                        "const": "mcp_schema_registry"
                    }
                }
            },
            "then":
            {
                "properties":
                {
                    "type":
                    {
                        "const": "mcp_schema_registry"
                    },
                    "kind":
                    {
                        "enum": [ "proxy" ]
                    },
                    "catalog": false,
                    "vault": false,
                    "entry": false,
                    "routes":
                    {
                        "title": "Routes",
                        "type": "array",
                        "minItems": 1,
                        "items":
                        {
                            "type": "object",
                            "properties":
                            {
                                "when":
                                {
                                    "title": "When",
                                    "type": "array",
                                    "minItems": 1,
                                    "items":
                                    {
                                        "type": "object",
                                        "properties":
                                        {
                                            "tool":
                                            {
                                                "title": "Tool",
                                                "enum":
                                                [
                                                    "list_subjects",
                                                    "describe_subject",
                                                    "get_schema",
                                                    "register_schema",
                                                    "delete_subject",
                                                    "delete_schema_version",
                                                    "check_compatibility",
                                                    "get_compatibility",
                                                    "set_compatibility",
                                                    "list_contexts"
                                                ]
                                            }
                                        },
                                        "required": [ "tool" ],
                                        "additionalProperties": false
                                    }
                                }
                            },
                            "required": [ "when", "exit" ]
                        }
                    }
                },
                "required": [ "routes" ]
            }
        }
    }
]
