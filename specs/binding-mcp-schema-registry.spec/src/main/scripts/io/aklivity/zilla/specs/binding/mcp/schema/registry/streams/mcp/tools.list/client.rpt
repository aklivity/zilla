connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsList()
                               .sessionId("session-1")
                               .build()
                           .build()}

connected

# tools/list answered from the generated mcp_openapi config, without any call
# reaching Karapace -- the fixed nine-tool set is known statically from the
# bundled spec's routes.
read  '{"tools":[{"name":"list_subjects","description":"list_subjects","inputSchema":{"type":"object","properties":{}}},'
        '{"name":"describe_subject","description":"describe_subject","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"}},"required":["subject"]}},'
        '{"name":"get_schema","description":"get_schema","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"},"version":{"type":"string"}},"required":["subject","version"]}},'
        '{"name":"register_schema","description":"register_schema","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"},"schema":{"type":"string"},"schemaType":{"type":"string"}},'
        '"required":["subject"]}},'
        '{"name":"delete_subject","description":"delete_subject","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"}},"required":["subject"]}},'
        '{"name":"delete_schema_version","description":"delete_schema_version","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"},"version":{"type":"string"}},"required":["subject","version"]}},'
        '{"name":"check_compatibility","description":"check_compatibility","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"},"version":{"type":"string"},"schema":{"type":"string"},'
        '"schemaType":{"type":"string"}},"required":["subject","version"]}},'
        '{"name":"get_compatibility","description":"get_compatibility","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"}},"required":["subject"]}},'
        '{"name":"set_compatibility","description":"set_compatibility","inputSchema":{"type":"object",'
        '"properties":{"subject":{"type":"string"},"compatibility":{"type":"string"}},"required":["subject"]}}]}'
read closed

write close
