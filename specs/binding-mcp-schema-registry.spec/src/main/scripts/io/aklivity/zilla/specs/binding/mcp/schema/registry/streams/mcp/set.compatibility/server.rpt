property serverAddress "zilla://streams/app0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                            .typeId(zilla:id("mcp"))
                            .lifecycle()
                                .sessionId("session-1")
                                .build()
                            .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsCall()
                              .sessionId("session-1")
                              .name("set_compatibility")
                              .contentLength(94)
                              .build()
                          .build()}

connected

read  '{"name":"set_compatibility","arguments":{"subject":"orders-value","compatibility":"BACKWARD"}}'

write flush

write '{"structuredContent":{"compatibility":"BACKWARD"},"content":[{"type":"text","text":"Compatibility level set to BACKWARD"}],"isError":false}'
write flush

write close

read closed
