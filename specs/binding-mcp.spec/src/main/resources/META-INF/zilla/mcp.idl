scope mcp
{
    union McpSessionId switch (uint8)
    {
        case 0: string16 text;
        case 1: int64 id;
    }

    scope stream
    {
        union McpBeginEx switch (uint8) extends core::stream::Extension
        {
            case 0: mcp::stream::McpInitializeBeginEx initialize;
            case 1: mcp::stream::McpPingBeginEx ping;
            case 2: mcp::stream::McpToolsBeginEx tools;
            case 3: mcp::stream::McpToolBeginEx tool;
            case 4: mcp::stream::McpPromptsBeginEx prompts;
            case 5: mcp::stream::McpPromptBeginEx prompt;
            case 6: mcp::stream::McpResourcesBeginEx resources;
            case 7: mcp::stream::McpResourceBeginEx resource;
            case 8: mcp::stream::McpCompletionBeginEx completion;
            case 9: mcp::stream::McpLoggingBeginEx logging;
            case 10: mcp::stream::McpCancelBeginEx cancel;
            case 11: mcp::stream::McpDisconnectBeginEx disconnect;
        }

        struct McpInitializeBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpPingBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpToolsBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpToolBeginEx
        {
            mcp::McpSessionId sessionId;
            string16 name = null;
        }

        struct McpPromptsBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpPromptBeginEx
        {
            mcp::McpSessionId sessionId;
            string16 name = null;
        }

        struct McpResourcesBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpResourceBeginEx
        {
            mcp::McpSessionId sessionId;
            string16 uri = null;
        }

        struct McpCompletionBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpLoggingBeginEx
        {
            mcp::McpSessionId sessionId;
            string16 level = null;
        }

        struct McpCancelBeginEx
        {
            mcp::McpSessionId sessionId;
            string16 reason = null;
        }

        struct McpDisconnectBeginEx
        {
            mcp::McpSessionId sessionId;
        }

        struct McpAbortEx extends core::stream::Extension
        {
            string16 reason = null;
        }
    }
}
