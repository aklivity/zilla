# capabilities = SERVER_TOOLS (1) | SERVER_PROMPTS (2) | SERVER_RESOURCES (4)
#              | SERVER_RESOURCES_LIST_CHANGED (256)
#              = 263

connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1")
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .capabilities(263)
                              .build()
                          .build()}
