write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .resourcesList()
                               .sessionId("hydrate-1")
                               .build()
                           .build()}

connected

read '{"resources":[{"uri":"file:///quartz.txt"}]}'
