connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("agent-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsCall()
                               .sessionId("agent-1")
                               .name("zilla__describe_tool")
                               .contentLength(72)
                               .build()
                           .build()}

connected

# this caller presents no credentials at all (default session 0), which the test0 guard never
# admits once credentials are configured -- get_secret_report requires the report:read scope via
# its securitySchemes entry, so the request is denied the same way a not-found lookup would be,
# without revealing whether the tool exists at all
write '{'
        '"name":"zilla__describe_tool",'
        '"arguments":'
        '{'
          '"name": "get_secret_report"'
        '}'
      '}'

write close

read  '{"content":[{"type":"text","text":"Tool not found"}],"isError":true}'
read closed
