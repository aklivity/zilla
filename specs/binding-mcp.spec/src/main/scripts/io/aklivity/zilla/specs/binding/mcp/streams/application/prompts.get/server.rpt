accept "zilla://streams/app0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1")
                               .build()
                           .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .promptsGet()
                              .sessionId("session-1")
                              .name("weather_prompt")
                              .build()
                          .build()}

connected

read  '{"name":"weather_prompt"}'
read closed

write '{"messages":[{"role":"user","content":{"type":"text","text":"What is the weather like today?"}}]}'
write flush

write close
