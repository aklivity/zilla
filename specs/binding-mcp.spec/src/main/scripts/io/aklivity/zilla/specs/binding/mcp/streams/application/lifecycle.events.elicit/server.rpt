accept "zilla://streams/app0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1")
                               .build()
                           .build()}
write flush

write advised zilla:challenge ${mcp:matchChallengeEx()
                                    .typeId(zilla:id("mcp"))
                                    .resume()
                                        .build()
                                    .build()}

write advise zilla:flush ${mcp:flushEx()
                              .typeId(zilla:id("mcp"))
                              .resumable()
                                  .build()
                              .build()}

write advise zilla:flush ${mcp:flushEx()
                              .typeId(zilla:id("mcp"))
                              .resumable()
                                  .id("0")
                                  .build()
                              .build()}

read advise zilla:challenge ${mcp:challengeEx()
                                  .typeId(zilla:id("mcp"))
                                  .elicitCreate()
                                      .id("remote-1")
                                      .url("https://remote.example.com/authorize?state=remote-nonce")
                                      .build()
                                  .build()}

write advise zilla:flush ${mcp:flushEx()
                              .typeId(zilla:id("mcp"))
                              .elicitComplete()
                                  .id("remote-1")
                                  .build()
                              .build()}

read closed
