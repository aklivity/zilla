connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("hydrate-A")
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("hydrate-A")
                              .build()
                          .build()}

read notify A_LIFECYCLE

connect await A_LIFECYCLE
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsList()
                               .sessionId("hydrate-A")
                               .build()
                           .build()}

connected

write close

read '{"tools":[{"name":"get_weather"}]}'
read closed

read notify A_HYDRATED

connect await A_HYDRATED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("hydrate-B")
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("hydrate-B")
                              .build()
                          .build()}

read notify B_LIFECYCLE

connect await B_LIFECYCLE
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsList()
                               .sessionId("hydrate-A")
                               .build()
                           .build()}

connected

write close

read '{"tools":[{"name":"get_weather"},{"name":"get_time"}]}'
read closed
