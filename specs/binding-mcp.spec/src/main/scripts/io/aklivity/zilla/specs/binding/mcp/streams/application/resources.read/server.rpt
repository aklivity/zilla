accept "zilla://streams/app0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1")
                               .build()
                           .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .resourcesRead()
                              .sessionId("session-1")
                              .uri("file:///data/readme.txt")
                              .build()
                          .build()}

connected

read  '{"uri":"file:///data/readme.txt"}'
read closed

write '{"contents":[{"uri":"file:///data/readme.txt","mimeType":"text/plain","text":"Hello World"}]}'
write flush

write close
