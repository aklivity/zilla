accept "zilla://streams/app1"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1a")
                               .build()
                           .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsList()
                              .sessionId("session-1a")
                              .build()
                          .build()}

connected

write flush

write '{"tools":'
        '['
          '{"name":"get_weather"}'
        ']'
      '}'
write flush

write close

read closed

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsList()
                              .sessionId("session-1a")
                              .build()
                          .build()}

connected

write flush

write '{"tools":'
        '['
          '{"name":"get_weather"}'
        ']'
      '}'
write flush

write close

read closed

accept "zilla://streams/app2"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

read advise zilla:challenge ${mcp:challengeEx()
                                 .typeId(zilla:id("mcp"))
                                 .elicitCreate()
                                     .id("1")
                                     .url("https://server.example.com/authorize?state=7f3a9b1c&redirect_uri=%s".formatted(http:encodeQuery("https://replace.me/callback")))
                                     .build()
                                 .build()}

write await FIRST_LIST_DONE

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1b")
                               .build()
                           .build()}
write flush

write advise zilla:flush ${mcp:flushEx()
                              .typeId(zilla:id("mcp"))
                              .toolsListChanged()
                                  .id("200")
                                  .build()
                              .build()}

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsList()
                              .sessionId("session-1b")
                              .build()
                          .build()}

connected

write flush

write '{"tools":'
        '['
          '{"name":"get_current_time"}'
        ']'
      '}'
write flush

write close

read closed
