property serverAddress "zilla://streams/app0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("agent-1")
                               .build()
                           .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsList()
                              .sessionId("agent-1")
                              .build()
                          .build()}

connected

write flush

write '{"tools":'
        '['
          '{'
            '"name":"github__list_repos",'
            '"description":"List repositories"'
          '}'
          ','
          '{'
            '"name":"zilla__search_tools",'
            '"description":"Search the tool catalog by relevance and return references to matching tools.",'
            '"inputSchema":{'
              '"type":"object",'
              '"properties":{'
                '"query":{"type":"string","description":"Natural-language search query"},'
                '"max_results":{"type":"integer","description":"Maximum number of results to return"}'
              '},'
              '"required":["query"]'
            '}'
          '}'
          ','
          '{'
            '"name":"zilla__describe_tool",'
            '"description":"Look up the full definition (including input/output schema) of a specific tool discovered via search_tools.",'
            '"inputSchema":{'
              '"type":"object",'
              '"properties":{'
                '"name":{"type":"string","description":"Exact tool name, as returned by search_tools"}'
              '},'
              '"required":["name"]'
            '}'
          '}'
          ','
          '{'
            '"name":"zilla__execute_tool",'
            '"description":"Invoke a specific tool by name, exactly as tools/call would, once its schema is known via describe_tool.",'
            '"inputSchema":{'
              '"type":"object",'
              '"properties":{'
                '"name":{"type":"string","description":"Exact tool name, as returned by search_tools"},'
                '"arguments":{"type":"object","description":"Arguments to pass to the named tool"}'
              '},'
              '"required":["name"]'
            '}'
          '}'
        ']'
      '}'
write flush

write close

read closed
