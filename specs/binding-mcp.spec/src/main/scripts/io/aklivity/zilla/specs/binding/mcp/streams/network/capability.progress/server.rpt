accept "zilla://streams/net0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":path", "/mcp")
                           .header("content-type", "application/json")
                           .header("accept", "text/event-stream, application/json")
                           .header("mcp-protocol-version", "2025-11-25")
                           .header("mcp-session-id", "test-session-id")
                           .build()}

connected

read '{"jsonrpc":"2.0","id":4,"method":"tools/call","params":{"name":"long-running","arguments":{},"_meta":{"progressToken":1}}}'
read closed

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "200")
                            .header("content-type", "text/event-stream")
                            .build()}
write flush

write 'data: {"jsonrpc":"2.0","method":"notifications/progress","params":{"progressToken":1,"progress":50,"total":100}}\n\n'
write flush

write 'data: {"jsonrpc":"2.0","id":4,"result":{"content":[{"type":"text","text":"Done"}]}}\n\n'
write flush

write close
