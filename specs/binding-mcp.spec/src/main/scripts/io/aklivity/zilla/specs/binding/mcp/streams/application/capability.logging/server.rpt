accept "zilla://streams/app0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .logging()
                              .sessionId("test-session-id")
                              .level("error")
                              .build()
                          .build()}

connected

read '{"level":"error"}'
read closed

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .logging()
                               .sessionId("test-session-id")
                               .build()
                           .build()}
write flush

write '{}'
write flush

write close
