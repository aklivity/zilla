accept "zilla://streams/kafka0"
    option zilla:window 8192
    option zilla:transmission "duplex"


accepted

read zilla:begin.ext ${kafka:beginEx()
                               .typeId(zilla:id("kafka"))
                               .meta()
                                   .topic("mqtt-messages")
                                   .build()
                               .build()}

connected

write zilla:data.ext ${kafka:dataEx()
                             .typeId(zilla:id("kafka"))
                             .meta()
                                 .partition(0, -2)
                                 .partition(1, -2)
                                 .build()
                             .build()}
write flush

read closed
write close


accepted

read zilla:begin.ext ${kafka:beginEx()
                               .typeId(zilla:id("kafka"))
                               .meta()
                                   .topic("mqtt-retained")
                                   .build()
                               .build()}

connected

write zilla:data.ext ${kafka:dataEx()
                             .typeId(zilla:id("kafka"))
                             .meta()
                                 .partition(0, -2)
                                 .build()
                             .build()}
write flush

read closed
write close


accepted

read zilla:begin.ext ${kafka:matchBeginEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                                .capabilities("FETCH_ONLY")
                                .topic("mqtt-sessions")
                                .filter()
                                    .key("client#offsets")
                                    .build()
                                .build()
                            .build()}

connected

write zilla:data.ext ${kafka:dataEx()
                           .typeId(zilla:id("kafka"))
                           .merged()
                             .fetch()
                               .partition(-1, -1)
                               .key("client#offsets")
                               .build()
                           .build()}
write ${mqtt_kafka:sessionOffsets()
            .entry("mqtt-messages", 0, 100, 12345, 3, 0)
                .packetId(1)
            .entry("mqtt-messages", 1, 70, 12345, 3, 0)
                .packetId(2)
            .entry("mqtt-retained", 0, 10, 12345, 3, 0)
                .packetId(3)
            .build()}
write flush

read closed
write close


accepted

read zilla:begin.ext ${kafka:matchBeginEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                                .capabilities("PRODUCE_ONLY")
                                .topic("mqtt-sessions")
                                .build()
                            .build()}

connected

read zilla:data.ext ${kafka:matchDataEx()
                           .typeId(zilla:id("kafka"))
                           .merged()
                             .produce()
                               .deferred(0)
                               .partition(-1, -1)
                               .key("client#offsets")
                               .hashKey("client")
                               .build()
                           .build()}
read ${mqtt_kafka:sessionOffsets()
            .entry("mqtt-messages", 0, 100, 12345, 3, 0)
                .packetId(1)
            .entry("mqtt-messages", 1, 70, 12345, 3, 0)
                .packetId(2)
            .entry("mqtt-retained", 0, 10, 12345, 3, 0)
                .packetId(3)
            .build()}

read zilla:data.ext ${kafka:matchDataEx()
                           .typeId(zilla:id("kafka"))
                           .merged()
                             .produce()
                               .deferred(0)
                               .partition(-1, -1)
                               .key("client#offsets")
                               .hashKey("client")
                               .build()
                           .build()}
read ${mqtt_kafka:sessionOffsets()
            .entry("mqtt-messages", 0, 101, 12345, 3, 0)
            .entry("mqtt-messages", 1, 70, 12345, 3, 0)
                .packetId(2)
            .entry("mqtt-retained", 0, 10, 12345, 3, 0)
                .packetId(3)
            .build()}


accepted

read zilla:begin.ext ${kafka:matchBeginEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                                .capabilities("PRODUCE_AND_FETCH")
                                .topic("mqtt-sessions")
                                .filter()
                                    .key("client")
                                    .build()
                                .build()
                            .build()}

connected

write advise zilla:flush
