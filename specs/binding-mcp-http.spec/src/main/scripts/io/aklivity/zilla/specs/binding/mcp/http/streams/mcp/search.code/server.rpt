property serverAddress "zilla://streams/app0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                            .typeId(zilla:id("mcp"))
                            .lifecycle()
                                .sessionId("session-1")
                                .build()
                            .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsCall()
                              .sessionId("session-1")
                              .name("search_code")
                              .contentLength(64)
                              .build()
                          .build()}

connected

read  '{"name":"search_code","arguments":{"q":"addClass","per_page":5}}'

write flush

write '{'
        '"structuredContent":{"total_count":2,"items":[{"path":"src/a.js"},{"path":"src/b.js"}]},'
        '"content":[{"type":"text","text":"Found 2 matches"}],'
        '"isError":false'
      '}'
write flush

write close

read closed
