                                                                "^[A-Za-z0-9_-]+$":
                                                                {
                                                                    "type": "string"
                                                                }
                                                            },
                                                            "additionalProperties": false
                                                        }
                                                    },
                                                    "required": [ "template" ],
                                                    "additionalProperties": false
                                                }
                                            ]
                                        }
                                    },
                                    "required": [ "headers" ],
                                    "additionalProperties": false
                                }
                            }
