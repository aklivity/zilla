property serverAddress "zilla://streams/app0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                            .typeId(zilla:id("mcp"))
                            .lifecycle()
                                .sessionId("session-1")
                                .build()
                            .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .promptsGet()
                              .sessionId("session-1")
                              .name("summarize")
                              .contentLength(50)
                              .build()
                          .build()}

connected

read  '{"name":"summarize","arguments":{"topic":"kafka"}}'

write '{"description":"Summarize a document about a topic",'
      '"messages":[{"role":"user","content":{"type":"text",'
      '"text":"Please summarize the document about kafka."}}]}'
write flush

write close

read closed
