property serverAddress "zilla://streams/http0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

# assert the binding injected the guard credentials as the authorization header, and substituted the
# guard identity into the x-user-identity header (the {identity} substitution path, distinct from the
# {credentials} path also asserted here)
read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":scheme", "https")
                           .header(":authority", "api.github.com:443")
                           .header(":path", "/repos/acme/widget/pulls")
                           .header("content-type", "application/json")
                           .header("authorization", "Bearer ghp_secret")
                           .header("x-user-identity", "test")
                           .build()}

connected

read  '{"title":"Add feature","head":"feature","base":"main"}'

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "201")
                            .header("content-type", "application/json")
                            .build()}
write flush

write '{"number":42,"html_url":"https://github.com/acme/widget/pull/42","state":"open","title":"Add feature",'
      '"body":"please review","draft":false,"merged":false,"user":{"login":"acme-bot"}}'
write flush

write close

read closed
