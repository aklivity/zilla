                                            }
                                        },
                                        "additionalProperties": false
                                    }
                                },
                                "with":
                                {
                                    "properties":
                                    {
                                        "method":
                                        {
                                            "title": "HTTP Method",
                                            "type": "string",
                                            "enum": [ "GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS" ]
                                        },
                                        "headers":
                                        {
                                            "title": "HTTP Headers",
                                            "type": "object",
                                            "additionalProperties":
                                            {
                                                "type": "string"
                                            }
                                        }
                                    },
                                    "additionalProperties": false
                                }
                            },
                            "required":
