                                                "properties":
                                                {
                                                    "input":
                                                    {
                                                        "title": "Input Schema",
                                                        "type": "object"
                                                    },
                                                    "output":
                                                    {
                                                        "title": "Output Schema",
                                                        "type": "object"
                                                    }
                                                },
                                                "additionalProperties": false
                                            }
                                        },
                                        "additionalProperties": false
                                    }
                                }
                            }
                        },
                        "additionalProperties": false
                    },
                    "routes":
                    {
                        "title": "Routes",
