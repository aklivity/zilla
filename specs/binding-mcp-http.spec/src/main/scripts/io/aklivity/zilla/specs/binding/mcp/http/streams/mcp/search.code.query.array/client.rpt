connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsCall()
                               .sessionId("session-1")
                               .name("search_code")
                               .contentLength(93)
                               .build()
                           .build()}

connected

write '{"name":"search_code","arguments":{"q":"addClass","labels":["bug","urgent"],"archived":true}}'

# response projected through schemas.output (search_code_result): total_count + items[].path only
read  '{'
        '"structuredContent":{"total_count":1,"items":[{"path":"src/c.js"}]},'
        '"content":[{"type":"text","text":"Found 1 matches"}],'
        '"isError":false'
      '}'
read closed

write close
