property serverAddress "zilla://streams/http0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "GET")
                           .header(":scheme", "https")
                           .header(":authority", "api.orders.internal:443")
                           .header(":path", "/orders/12345")
                           .build()}

connected

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "500")
                            .header("content-type", "application/json")
                            .build()}
write flush

# body would satisfy order_result (total: number) if the status were 2xx
write '{"id":"12345","status":"shipped","total":42.5}'
write flush

write close

read closed

# only once the full response round trip has completed can the client safely expect the
# proxy to have already reacted to the non-2xx status and sent its abort
write notify RESPONSE_SENT
