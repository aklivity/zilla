connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

# no lifecycle handshake was performed, so the session id is unknown and the binding rejects the stream
write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsList()
                               .sessionId("session-unknown")
                               .build()
                           .build()}

connect aborted
