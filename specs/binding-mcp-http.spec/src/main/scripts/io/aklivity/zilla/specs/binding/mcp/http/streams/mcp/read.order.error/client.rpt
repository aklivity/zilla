connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .resourcesRead()
                               .sessionId("session-1")
                               .uri("order://12345")
                               .contentLength(23)
                               .build()
                           .build()}

connected

write '{"uri":"order://12345"}'

# wait for the full upstream response round trip to complete before expecting the abort, so
# this isn't racing the response delivery itself
read await RESPONSE_SENT

# upstream responds with a non-2xx status even though the body would otherwise satisfy
# with.response; resources/read carries no isError, so the reply stream is aborted
read abort
