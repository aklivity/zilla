# Mocks the http server binding's behavior when the affinity key is owned
# by a peer instance: read the request, immediately respond with 429
# + retry-after: 0 + alt-svc pointing at the peer authority.

accept "http://server.example.com:8080/items"
  option http:transport "zilla://streams/net0"
  option zilla:window 8192
  option zilla:transmission "duplex"
accepted
connected

read http:method "GET"
read http:header "session-id" "sess-1"
read closed

write http:status "429" "Too Many Requests"
write http:header "retry-after" "0"
write http:header "alt-svc" "http/1.1=\"peer-1.example.net:8080\"; ma=86400"
write close
