connect "zilla://streams/net0"
  option zilla:window 8192
  option zilla:transmission "duplex"
connected

# Request 1
write "GET /request1 HTTP/1.1" "\r\n"
write "Host: localhost:8080" "\r\n"
write "\r\n"
write notify REQUEST_ONE_WRITTEN

write await REQUEST_ONE_RECEIVED
write notify WRITE_RESPONSE_ONE

read "HTTP/1.1 200 OK\r\n"
read "Content-Length: 9" "\r\n"
read "\r\n"
read "response1"

# Request 3 reuses this connection after both responses complete

read await RESPONSE_TWO_RECEIVED
write notify WRITE_RESPONSE_THREE

write "GET /request3 HTTP/1.1" "\r\n"
write "Host: localhost:8080" "\r\n"
write "\r\n"

read "HTTP/1.1 200 OK\r\n"
read "Content-Length: 9" "\r\n"
read "\r\n"
read "response3"

connect await REQUEST_ONE_WRITTEN
        "zilla://streams/net0"
  option zilla:window 8192
  option zilla:transmission "duplex"
connected

# Request 2
write "GET /request2 HTTP/1.1" "\r\n"
write "Host: localhost:8080" "\r\n"
write "\r\n"

write await REQUEST_TWO_RECEIVED
write notify WRITE_RESPONSE_TWO

read "HTTP/1.1 200 OK\r\n"
read "Content-Length: 9" "\r\n"
read "\r\n"
read "response2"

read notify RESPONSE_TWO_RECEIVED
