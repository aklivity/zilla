# Verifies that a request body of unknown-upfront length, delivered to the
# HTTP/1.1 client encoder as a single complete (INIT+FIN) application DATA
# frame, is written to the network as a correctly framed HTTP/1.1 chunk:
# <hex-size>\r\n<payload>\r\n followed by the terminating 0\r\n\r\n chunk.
#
# This asserts the literal wire bytes rather than relying on a higher-level
# HTTP codec to transparently dechunk the body, so that any regression in the
# chunk-size-prefix / payload / trailing-CRLF offset bookkeeping is caught
# directly instead of being masked by a permissive protocol-aware reader.

accept "zilla://streams/net0"
  option zilla:window 8192
  option zilla:transmission "duplex"
accepted
connected

read "POST / HTTP/1.1\r\n"
read "Host: localhost:8080\r\n"
read "Content-Type: text/plain\r\n"
read "Transfer-Encoding: chunked\r\n"
read "\r\n"
read "15\r\n"
read "Hello, chunked world!\r\n"
read "0\r\n"
read "\r\n"

write "HTTP/1.1 200 OK\r\n"
write "Content-Length: 0\r\n"
write "\r\n"
