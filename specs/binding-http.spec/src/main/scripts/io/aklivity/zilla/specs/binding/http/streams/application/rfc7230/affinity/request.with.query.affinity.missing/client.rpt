# affinity source (`state` query parameter) absent from request, so the
# route's affinity rule yields no key and the application BEGIN carries
# the network-level affinity (here defaulted to 0L)

connect "zilla://streams/app0"
    option zilla:window 8192
    option zilla:transmission "half-duplex"

write zilla:begin.ext ${http:beginEx()
                              .typeId(zilla:id("http"))
                              .header(":scheme", "https")
                              .header(":method", "GET")
                              .header(":path", "/auth/callback")
                              .header(":authority", "server.example.com")
                              .build()}
connected

write close

read zilla:begin.ext ${http:beginEx()
                             .typeId(zilla:id("http"))
                             .header(":status", "200")
                             .build()}

read closed
