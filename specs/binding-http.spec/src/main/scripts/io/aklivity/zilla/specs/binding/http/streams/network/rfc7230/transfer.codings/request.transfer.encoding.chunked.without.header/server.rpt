# Verifies that when the application layer supplies neither content-length nor
# transfer-encoding for a request that carries a body, the HTTP/1.1 client
# encoder infers unknown-length framing on its own -- adding the
# Transfer-Encoding: chunked header itself -- rather than requiring every
# caller to declare an HTTP/1.1-specific header up front.

accept "zilla://streams/net0"
  option zilla:window 8192
  option zilla:transmission "duplex"
accepted
connected

read "POST / HTTP/1.1\r\n"
read "Host: localhost:8080\r\n"
read "Content-Type: text/plain\r\n"
read "Transfer-Encoding: chunked\r\n"
read "\r\n"
read "15\r\n"
read "Hello, chunked world!\r\n"
read "0\r\n"
read "\r\n"

write "HTTP/1.1 200 OK\r\n"
write "Content-Length: 0\r\n"
write "\r\n"
