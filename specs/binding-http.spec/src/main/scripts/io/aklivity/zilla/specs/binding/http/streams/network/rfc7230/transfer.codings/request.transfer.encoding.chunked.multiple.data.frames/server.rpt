# Verifies that a request body delivered to the HTTP/1.1 client encoder across
# multiple application DATA frames (separately flushed) is written to the
# network as multiple correctly framed HTTP/1.1 chunks, exercising the
# chunk-size-prefix / payload / trailing-CRLF bookkeeping across repeated
# doEncodeHttp1Body invocations rather than a single one-shot call.

accept "zilla://streams/net0"
  option zilla:window 8192
  option zilla:transmission "duplex"
accepted
connected

read "POST / HTTP/1.1\r\n"
read "Host: localhost:8080\r\n"
read "Content-Type: text/plain\r\n"
read "Transfer-Encoding: chunked\r\n"
read "\r\n"
read "5\r\n"
read "AAAAA\r\n"
read "5\r\n"
read "BBBBB\r\n"
read "5\r\n"
read "CCCCC\r\n"
read "0\r\n"
read "\r\n"

write "HTTP/1.1 200 OK\r\n"
write "Content-Length: 0\r\n"
write "\r\n"
