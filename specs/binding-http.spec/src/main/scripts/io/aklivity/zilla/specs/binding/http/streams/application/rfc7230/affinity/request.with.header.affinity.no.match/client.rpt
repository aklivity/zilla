# header value is "no-dots-here"; the binding's affinity rule uses
# match: "[^.]+\.([^.]+)\.[^.]+" which does NOT match this value.
# Rule yields no key, so the BEGIN flows through with the network-level
# affinity (default 0L) unchanged.

connect "zilla://streams/app0"
    option zilla:window 8192
    option zilla:transmission "half-duplex"

write zilla:begin.ext ${http:beginEx()
                              .typeId(zilla:id("http"))
                              .header(":scheme", "https")
                              .header(":method", "GET")
                              .header(":path", "/items")
                              .header(":authority", "server.example.com")
                              .header("session-id", "no-dots-here")
                              .build()}
connected

write close

read zilla:begin.ext ${http:beginEx()
                             .typeId(zilla:id("http"))
                             .header(":status", "200")
                             .build()}

read closed
