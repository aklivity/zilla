# header value is "prefix.sess-1.suffix"; the binding's affinity rule
# uses match: "[^.]+\.([^.]+)\.[^.]+" which captures group 1 = "sess-1"
# affinity = "sess-1".hashCode() & 0xffff_ffffL = 0xca029156

accept "zilla://streams/app0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"
       option zilla:affinity 0x00000000ca029156L
accepted

read zilla:begin.ext ${http:beginEx()
                             .typeId(zilla:id("http"))
                             .header(":scheme", "http")
                             .header(":method", "GET")
                             .header(":path", "/items/match")
                             .header(":authority", "server.example.com:8080")
                             .header("session-id", "prefix.sess-1.suffix")
                             .build()}
connected

read closed

write zilla:begin.ext ${http:beginEx()
                              .typeId(zilla:id("http"))
                              .header(":status", "200")
                              .build()}
write flush

write close
