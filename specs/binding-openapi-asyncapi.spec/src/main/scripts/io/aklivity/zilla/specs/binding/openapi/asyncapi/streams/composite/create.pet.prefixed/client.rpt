connect "http://localhost:9090/apis/pets"
connected

write http:method "POST"
write http:host
write http:header "content-type" "application/json"
write http:content-length

write "{\"id\": 1, \"name\": \"Dog\", \"tag\": \"test\"}"
write close

read http:status "204" "No Content"

read closed
