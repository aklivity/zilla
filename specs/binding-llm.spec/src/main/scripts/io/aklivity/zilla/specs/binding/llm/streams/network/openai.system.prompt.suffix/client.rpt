# dialect: openai
# streaming: false
# aspect: openai system prompt suffix injection — configured text appended after existing system content

connect "zilla://streams/net0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":method", "POST")
                            .header(":scheme", "https")
                            .header(":authority", "api.openai.com")
                            .header(":path", "/v1/chat/completions")
                            .header("content-type", "application/json")
                            .build()}

connected

write '{"model":"gpt-4o-mini","messages":[{"role":"system","content":"You speak French.\\nYou are a careful assistant."},{"role":"user","content":"Bonjour"}]}'
write close

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":status", "200")
                           .header("content-type", "application/json")
                           .build()}

read '{"id":"chatcmpl-s","object":"chat.completion","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"message":{"role":"assistant","content":"Bonjour !"},"finish_reason":"stop"}],"usage":{"prompt_tokens":10,"completion_tokens":3,"total_tokens":13}}'
read closed
