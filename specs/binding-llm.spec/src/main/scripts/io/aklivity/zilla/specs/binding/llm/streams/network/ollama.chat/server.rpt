# dialect: ollama
# streaming: false
# aspect: POST /api/chat non-streaming single JSON response

accept "zilla://streams/net0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":path", "/api/chat")
                           .header("content-type", "application/json")
                           .build()}

connected

read '{"model":"llama3","messages":[{"role":"user","content":"Hello"}],"stream":false}'
read closed

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "200")
                            .header("content-type", "application/json")
                            .build()}
write flush

write '{"model":"llama3","created_at":"2026-01-01T00:00:00Z","message":{"role":"assistant","content":"Hi there!"},"done":true,"done_reason":"stop","total_duration":1000000,"load_duration":100000,"prompt_eval_count":2,"prompt_eval_duration":50000,"eval_count":3,"eval_duration":150000}'
write flush

write close
