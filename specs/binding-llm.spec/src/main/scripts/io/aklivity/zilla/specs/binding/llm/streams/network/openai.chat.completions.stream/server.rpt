# dialect: openai
# streaming: true
# aspect: SSE chunked streaming with discriminated `object: chat.completion.chunk` events and terminal `data: [DONE]` sentinel

accept "zilla://streams/net0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":path", "/v1/chat/completions")
                           .header("content-type", "application/json")
                           .build()}

connected

read '{"model":"gpt-4o-mini","messages":[{"role":"user","content":"Hi"}],"stream":true}'
read closed

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "200")
                            .header("content-type", "text/event-stream")
                            .build()}
write flush

write 'data: {"id":"chatcmpl-2","object":"chat.completion.chunk","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"delta":{"role":"assistant","content":""},"finish_reason":null}]}\n\n'
write flush
write 'data: {"id":"chatcmpl-2","object":"chat.completion.chunk","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"delta":{"content":"Hello"},"finish_reason":null}]}\n\n'
write flush
write 'data: {"id":"chatcmpl-2","object":"chat.completion.chunk","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"delta":{},"finish_reason":"stop"}]}\n\n'
write flush
write 'data: [DONE]\n\n'
write flush

write close
