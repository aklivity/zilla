# dialect: openai
# streaming: false
# aspect: downward rewrite for capping — inbound max_tokens: 9999 is rewritten to configured cap of 512 before forwarding

accept "zilla://streams/net0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":path", "/v1/chat/completions")
                           .header("content-type", "application/json")
                           .build()}

connected

read '{"model":"gpt-4o-mini","max_tokens":512,"messages":[{"role":"user","content":"ping"}]}'
read closed

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "200")
                            .header("content-type", "application/json")
                            .build()}
write flush

write '{"id":"chatcmpl-a","object":"chat.completion","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"message":{"role":"assistant","content":"pong"},"finish_reason":"stop"}],"usage":{"prompt_tokens":1,"completion_tokens":1,"total_tokens":2}}'
write flush

write close
