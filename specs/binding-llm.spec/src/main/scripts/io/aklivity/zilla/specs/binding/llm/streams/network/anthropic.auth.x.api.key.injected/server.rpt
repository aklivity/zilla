# dialect: anthropic
# streaming: false
# aspect: anthropic outbound — x-api-key: <key> and anthropic-version headers injected, no authorization header

accept "zilla://streams/net0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":path", "/v1/messages")
                           .header("x-api-key", "sk-ant-xxx")
                           .header("anthropic-version", "2023-06-01")
                           .header("content-type", "application/json")
                           .build()}

connected

read '{"model":"claude-3-5-sonnet-20241022","max_tokens":1024,"messages":[{"role":"user","content":"ping"}]}'
read closed

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "200")
                            .header("content-type", "application/json")
                            .build()}
write flush

write '{"id":"msg_a","type":"message","role":"assistant","content":[{"type":"text","text":"pong"}],"model":"claude-3-5-sonnet-20241022","stop_reason":"end_turn","usage":{"input_tokens":1,"output_tokens":1}}'
write flush

write close
