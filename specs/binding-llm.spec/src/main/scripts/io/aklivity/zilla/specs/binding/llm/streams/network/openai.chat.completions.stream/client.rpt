# dialect: openai
# streaming: true
# aspect: SSE chunked streaming with discriminated `object: chat.completion.chunk` events and terminal `data: [DONE]` sentinel

connect "zilla://streams/net0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":method", "POST")
                            .header(":scheme", "https")
                            .header(":authority", "api.openai.com")
                            .header(":path", "/v1/chat/completions")
                            .header("content-type", "application/json")
                            .build()}

connected

write '{"model":"gpt-4o-mini","messages":[{"role":"user","content":"Hi"}],"stream":true}'
write close

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":status", "200")
                           .header("content-type", "text/event-stream")
                           .build()}

read 'data: {"id":"chatcmpl-2","object":"chat.completion.chunk","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"delta":{"role":"assistant","content":""},"finish_reason":null}]}\n\n'
read 'data: {"id":"chatcmpl-2","object":"chat.completion.chunk","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"delta":{"content":"Hello"},"finish_reason":null}]}\n\n'
read 'data: {"id":"chatcmpl-2","object":"chat.completion.chunk","created":1700000000,"model":"gpt-4o-mini","choices":[{"index":0,"delta":{},"finish_reason":"stop"}]}\n\n'
read 'data: [DONE]\n\n'
read closed
