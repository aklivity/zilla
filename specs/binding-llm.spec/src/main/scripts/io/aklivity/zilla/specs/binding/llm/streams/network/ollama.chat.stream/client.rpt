# dialect: ollama
# streaming: true
# aspect: POST /api/chat with NDJSON streaming

connect "zilla://streams/net0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":method", "POST")
                            .header(":scheme", "http")
                            .header(":authority", "localhost:11434")
                            .header(":path", "/api/chat")
                            .header("content-type", "application/json")
                            .build()}

connected

write '{"model":"llama3","messages":[{"role":"user","content":"Hello"}],"stream":true}'
write close

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":status", "200")
                           .header("content-type", "application/x-ndjson")
                           .build()}

read '{"model":"llama3","created_at":"2026-01-01T00:00:00Z","message":{"role":"assistant","content":"Hi"},"done":false}'
read '\n'
read '{"model":"llama3","created_at":"2026-01-01T00:00:00Z","message":{"role":"assistant","content":" there!"},"done":false}'
read '\n'
read '{"model":"llama3","created_at":"2026-01-01T00:00:00Z","message":{"role":"assistant","content":""},"done":true,"done_reason":"stop","total_duration":1000000,"eval_count":3}'
read '\n'
read closed
