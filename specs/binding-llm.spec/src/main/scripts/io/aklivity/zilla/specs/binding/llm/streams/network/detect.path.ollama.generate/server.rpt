# dialect: ollama
# streaming: false
# aspect: path-based detection — POST /api/generate resolves to ollama

accept "zilla://streams/net0"
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":path", "/api/generate")
                           .header("content-type", "application/json")
                           .build()}

connected

read '{"model":"llama3","prompt":"ping","stream":false}'
read closed

write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "200")
                            .header("content-type", "application/json")
                            .header("x-llm-dialect", "ollama")
                            .build()}
write flush

write '{"model":"llama3","created_at":"2026-01-01T00:00:00Z","response":"pong","done":true,"done_reason":"stop"}'
write flush

write close
