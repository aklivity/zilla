[
    {
        "op": "add",
        "path": "/$defs/models/types/enum/-",
        "value": "int32"
    },
    {
        "op": "add",
        "path": "/$defs/models/model/allOf/-",
        "value": {
            "if": {
                "properties": {
                    "model": {
                        "const": "int32"
                    }
                }
            },
            "then": {
                "properties": {
                    "model": {
                        "const": "int32"
                    },
                    "format": {
                        "type": "string",
                        "enum": [
                            "binary",
                            "text"
                        ],
                        "default": "text"
                    },
                    "range": {
                        "type": "string",
                        "pattern": "((?:\\(|\\[))(-?\\d+)?,(-?\\d+)?((?:\\)|\\]))"
                    },
                    "multiple": {
                        "type": "integer"
                    },
                    "validate": {
                        "$ref": "#/$defs/validate"
                    }
                },
                "additionalProperties": false
            }
        }
    }
]
