[
    {
        "op": "add",
        "path": "/$defs/models/types/enum/-",
        "value": "boolean"
    },
    {
        "op": "add",
        "path": "/$defs/models/model/allOf/-",
        "value": {
            "if": {
                "properties": {
                    "model": {
                        "const": "boolean"
                    }
                }
            },
            "then": {
                "properties": {
                    "model": {
                        "const": "boolean"
                    },
                    "validate": {
                        "$ref": "#/$defs/validate"
                    }
                },
                "additionalProperties": false
            }
        }
    }
]
