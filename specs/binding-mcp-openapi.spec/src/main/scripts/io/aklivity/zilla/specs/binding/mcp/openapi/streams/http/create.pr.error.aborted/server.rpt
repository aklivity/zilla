property serverAddress "zilla://streams/http0"

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"

accepted

read zilla:begin.ext ${http:matchBeginEx()
                           .typeId(zilla:id("http"))
                           .header(":method", "POST")
                           .header(":scheme", "https")
                           .header(":authority", "api.github.com")
                           .header(":path", "/repos/acme/widget/pulls")
                           .header("content-type", "application/json")
                           .build()}

connected

read  '{"title":"Add feature","head":"feature","base":"main"}'

# a non-2xx status begin puts the proxy into error-relay mode, which acquires the reply encodeSlot
# to stage the error envelope's opening bytes — then aborting before ever sending a body or end
# exercises the abort path with that slot still held, proving it gets released rather than leaked
write zilla:begin.ext ${http:beginEx()
                            .typeId(zilla:id("http"))
                            .header(":status", "500")
                            .header("content-type", "text/plain")
                            .build()}
write flush

write notify RESPONSE_STARTED

write abort
