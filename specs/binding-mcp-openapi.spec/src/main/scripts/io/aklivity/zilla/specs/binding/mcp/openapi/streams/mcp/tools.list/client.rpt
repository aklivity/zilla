connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsList()
                               .sessionId("session-1")
                               .build()
                           .build()}

connected

# tools/list answered from the generated mcp_http config; create_pr inputSchema is the
# flattened (path params + requestBody) schema derived from the OpenAPI operation
read  '{"tools":[{"name":"create_pr",'
        '"description":"Create a pull request to merge one branch into another.",'
        '"inputSchema":{"type":"object","properties":{"owner":{"type":"string"},"repo":{"type":"string"},'
        '"base":{"type":"string"},"body":{"type":"string"},"head":{"type":"string"},"title":{"type":"string"}},'
        '"required":["owner","repo","title","head","base"]},'
        '"outputSchema":{"type":"object","properties":{"number":{"type":"integer"},"html_url":{"type":"string"},'
        '"state":{"type":"string"},"title":{"type":"string"}}}}]}'
read closed

write close
