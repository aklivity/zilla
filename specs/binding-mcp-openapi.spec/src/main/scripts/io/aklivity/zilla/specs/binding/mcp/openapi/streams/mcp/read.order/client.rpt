connect "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/app0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .resourcesRead()
                               .sessionId("session-1")
                               .uri("/orders/12345")
                               .contentLength(23)
                               .build()
                           .build()}

connected

write '{"uri":"/orders/12345"}'

# {orderId} captured from the resource uri template -> ${params.orderId} in :path
# response projected through schemas.output (read_order-output): only id/status survive
read  '{"contents":[{"uri":"/orders/12345","mimeType":"application/json",'
      '"text":"{\\"id\\":\\"12345\\",\\"status\\":\\"shipped\\"}"}]}'
read closed

write close
