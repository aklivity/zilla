property authorization 0L

connect "zilla://streams/mcp0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"
        option zilla:authorization ${authorization}

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .build()
                           .build()}

connected

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .sessionId("session-1")
                              .build()
                          .build()}

read notify LIFECYCLE_INITIALIZED

connect await LIFECYCLE_INITIALIZED
        "zilla://streams/mcp0"
        option zilla:window 8192
        option zilla:transmission "half-duplex"
        option zilla:authorization ${authorization}

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .toolsCall()
                               .sessionId("session-1")
                               .name("produce")
                               .contentLength(64)
                               .build()
                           .build()}

connected

# "other" is not in the route's topic allowlist (see proxy.produce.topic.allowlist.yaml): the
# route only matches once the real topic is known, after args are captured, so this is rejected
# with a plain reset (no ext) from completeArgs, not the earlier tool-name-only pre-check
write '{"name":"produce","arguments":{"topic":"other","value":"hello"}}'

