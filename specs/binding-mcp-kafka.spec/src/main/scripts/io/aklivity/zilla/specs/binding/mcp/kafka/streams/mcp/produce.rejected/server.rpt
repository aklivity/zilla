property serverAddress "zilla://streams/mcp0"
property authorization 0L

accept ${serverAddress}
       option zilla:window 8192
       option zilla:transmission "half-duplex"
       option zilla:authorization ${authorization}

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .lifecycle()
                              .build()
                          .build()}

connected

write zilla:begin.ext ${mcp:beginEx()
                           .typeId(zilla:id("mcp"))
                           .lifecycle()
                               .sessionId("session-1")
                               .build()
                           .build()}
write flush

accepted

read zilla:begin.ext ${mcp:matchBeginEx()
                          .typeId(zilla:id("mcp"))
                          .toolsCall()
                              .sessionId("session-1")
                              .name("produce")
                              .contentLength(65)
                              .build()
                          .build()}

connected

read  '{'
        '"name":"produce",'
        '"arguments":'
        '{'
          '"topic":"orders",'
          '"value":"hello"'
        '}'
      '}'

write flush

write '{'
        '"content":'
        '['
          '{'
            '"type": "text",'
            '"text": "Failed to produce record to orders"'
          '}'
        '],'
        '"isError": true'
      '}'
write flush

write zilla:end.ext ${mcp:endEx()
                         .typeId(zilla:id("mcp"))
                         .outcome("ERROR")
                         .build()}
write close

read closed
