connect "zilla://streams/kafka0"
    option zilla:window 8192
    option zilla:transmission "duplex"

write zilla:begin.ext ${kafka:beginEx()
                             .typeId(zilla:id("kafka"))
                             .merged()
                                 .capabilities("FETCH_ONLY")
                                 .topic("orders")
                                 .partition(-1, -2)
                                 .build()
                             .build()}

connected

read zilla:data.ext ${kafka:matchDataEx()
                           .typeId(zilla:id("kafka"))
                           .merged()
                             .fetch()
                               .partition(0, 0, 1)
                               .progress(0, 1)
                               .key("key-1")
                               .header("h1", "hv1")
                               .build()
                           .build()}
read "value-1"

read zilla:data.ext ${kafka:matchDataEx()
                           .typeId(zilla:id("kafka"))
                           .merged()
                             .fetch()
                               .partition(0, 1, 2)
                               .progress(0, 2)
                               .build()
                           .build()}
read "value-2"

write close
read closed
