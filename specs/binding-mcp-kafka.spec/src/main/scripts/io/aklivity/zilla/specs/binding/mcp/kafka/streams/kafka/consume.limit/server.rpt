accept "zilla://streams/kafka0"
    option zilla:window 8192
    option zilla:transmission "duplex"

accepted

read zilla:begin.ext ${kafka:matchBeginEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                                .capabilities("FETCH_ONLY")
                                .topic("orders")
                                .partition(-1, -2)
                                .build()
                            .build()}

connected

write zilla:data.ext ${kafka:dataEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                               .fetch()
                                .partition(0, 0, 1)
                                .progress(0, 1)
                                .build()
                            .build()}
write "value-1"
write flush

write zilla:data.ext ${kafka:dataEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                               .fetch()
                                .partition(0, 1, 2)
                                .progress(0, 2)
                                .build()
                            .build()}
write "value-2"
write flush

write zilla:data.ext ${kafka:dataEx()
                            .typeId(zilla:id("kafka"))
                            .merged()
                               .fetch()
                                .partition(0, 2, 3)
                                .progress(0, 3)
                                .build()
                            .build()}
write "value-3"
write flush

read closed
write close
