[
    {
        "op": "add",
        "path": "/$defs/binding/properties/type/enum/-",
        "value": "mcp"
    },
    {
        "op": "add",
        "path": "/$defs/binding/allOf/-",
        "value":
        {
            "if":
            {
                "properties":
                {
                    "type":
                    {
                        "const": "mcp"
                    }
                }
            },
            "then":
            {
                "properties":
                {
                    "type":
                    {
                        "const": "mcp"
                    },
                    "kind":
                    {
                        "enum": [ "server", "client", "proxy" ]
                    },
                    "catalog": false,
                    "vault": false,
                    "entry": false
                },
                "allOf":
                [
                    {
                        "if":
                        {
                            "properties":
                            {
                                "kind":
                                {
                                    "const": "server"
                                }
                            }
                        },
                        "then":
                        {
                            "properties":
                            {
                                "options":
                                {
                                    "properties":
                                    {
                                        "elicitation":
                                        {
                                            "title": "Elicitation",
                                            "type": "object",
                                            "properties":
                                            {
                                                "callback":
                                                {
                                                    "title": "Authorization Callback Path",
                                                    "type": "string",
                                                    "default": "auth/callback"
                                                },
                                                "timeout":
                                                {
                                                    "title": "Elicitation Timeout",
                                                    "type": "string",
                                                    "format": "duration",
                                                    "default": "PT0S"
                                                }
                                            },
                                            "additionalProperties": false
                                        },
                                        "authorization":
                                        {
                                            "title": "Authorization",
                                            "type": "object",
                                            "patternProperties":
                                            {
                                                "^[A-Za-z0-9_-]+$":
                                                {
                                                    "type": "object",
                                                    "properties":
                                                    {
                                                        "credentials":
                                                        {
                                                            "title": "Credentials",
                                                            "type": "string",
                                                            "pattern": ".*\\{credentials\\}.*",
                                                            "default": "Bearer {credentials}"
                                                        }
                                                    },
                                                    "additionalProperties": false
                                                }
                                            },
                                            "additionalProperties": false,
                                            "maxProperties": 1
                                        }
                                    },
                                    "additionalProperties": false
                                },
                                "routes": false
                            }
                        }
                    },
                    {
                        "if":
                        {
                            "properties":
                            {
                                "kind":
                                {
                                    "const": "client"
                                }
                            }
                        },
                        "then":
                        {
                            "properties":
                            {
                                "options":
                                {
                                    "properties":
                                    {
                                        "server":
                                        {
                                            "title": "Server",
                                            "type": "string",
                                            "format": "uri",
                                            "pattern": "^https?://"
                                        },
                                        "authorization":
                                        {
                                            "title": "Authorization",
                                            "type": "object",
                                            "patternProperties":
                                            {
                                                "^[A-Za-z0-9_-]+$":
                                                {
                                                    "type": "object",
                                                    "properties":
                                                    {
                                                        "credentials":
                                                        {
                                                            "title": "Credentials",
                                                            "type": "string",
                                                            "default": "Bearer {credentials}"
                                                        }
                                                    },
                                                    "additionalProperties": false
                                                }
                                            },
                                            "additionalProperties": false,
                                            "maxProperties": 1
                                        }
                                    },
                                    "required": [ "server" ],
                                    "additionalProperties": false
                                },
                                "routes":
                                {
                                    "title": "Routes",
                                    "type": "array",
                                    "items":
                                    {
                                        "type": "object",
                                        "properties":
                                        {
                                            "when":
                                            {
                                                "title": "When",
                                                "type": "array",
                                                "items":
                                                {
                                                    "type": "object",
                                                    "properties":
                                                    {
                                                        "tools":
                                                        {
                                                            "title": "Tools",
                                                            "type": "array",
                                                            "items":
                                                            {
                                                                "type": "string"
                                                            }
                                                        },
                                                        "prompts":
                                                        {
                                                            "title": "Prompts",
                                                            "type": "array",
                                                            "items":
                                                            {
                                                                "type": "string"
                                                            }
                                                        },
                                                        "resources":
                                                        {
                                                            "title": "Resources",
                                                            "type": "array",
                                                            "items":
                                                            {
                                                                "type": "string"
                                                            }
                                                        }
                                                    },
                                                    "additionalProperties": false
                                                }
                                            }
                                        }
                                    }
                                }
                            },
                            "required": [ "options" ]
                        }
                    },
                    {
                        "if":
                        {
                            "properties":
                            {
                                "kind":
                                {
                                    "const": "proxy"
                                }
                            }
                        },
                        "then":
                        {
                            "properties":
                            {
                                "options":
                                {
                                    "properties":
                                    {
                                        "cache":
                                        {
                                            "title": "Cache",
                                            "type": "object",
                                            "properties":
                                            {
                                                "store":
                                                {
                                                    "title": "Store",
                                                    "type": "string"
                                                },
                                                "ttl":
                                                {
                                                    "title": "Refresh TTL",
                                                    "type": "string",
                                                    "format": "duration",
                                                    "default": "PT5M"
                                                },
                                                "authorization":
                                                {
                                                    "title": "Authorization",
                                                    "type": "object",
                                                    "patternProperties":
                                                    {
                                                        "^[A-Za-z0-9_-]+$":
                                                        {
                                                            "type": "object",
                                                            "properties":
                                                            {
                                                                "credentials":
                                                                {
                                                                    "title": "Credentials",
                                                                    "type": "string"
                                                                }
                                                            },
                                                            "additionalProperties": false
                                                        }
                                                    },
                                                    "additionalProperties": false,
                                                    "maxProperties": 1
                                                },
                                                "tools":
                                                {
                                                    "title": "Tools",
                                                    "type": "object",
                                                    "properties":
                                                    {
                                                        "search":
                                                        {
                                                            "title": "Search",
                                                            "type": "object",
                                                            "properties":
                                                            {
                                                                "toolkit":
                                                                {
                                                                    "title": "Toolkit",
                                                                    "type": "string"
                                                                },
                                                                "limit":
                                                                {
                                                                    "title": "Limit",
                                                                    "type": "integer",
                                                                    "default": 5
                                                                },
                                                                "fields":
                                                                {
                                                                    "title": "Fields",
                                                                    "type": "array",
                                                                    "items":
                                                                    {
                                                                        "enum": [ "name", "description", "output-schema" ]
                                                                    },
                                                                    "default": [ "name", "description" ]
                                                                },
                                                                "weights":
                                                                {
                                                                    "title": "Weights",
                                                                    "type": "object",
                                                                    "patternProperties":
                                                                    {
                                                                        "^[a-zA-Z0-9_-]+$":
                                                                        {
                                                                            "type": "number"
                                                                        }
                                                                    },
                                                                    "additionalProperties": false
                                                                },
                                                                "type":
                                                                {
                                                                    "title": "Type",
                                                                    "$ref": "#/$defs/binding-ext/mcp/indexes/flat"
                                                                },
                                                                "index":
                                                                {
                                                                    "title": "Index",
                                                                    "type": "array",
                                                                    "items":
                                                                    {
                                                                        "$ref": "#/$defs/binding-ext/mcp/indexes"
                                                                    }
                                                                }
                                                            },
                                                            "not": { "required": [ "type", "index" ] },
                                                            "additionalProperties": false
                                                        },
                                                        "eager":
                                                        {
                                                            "title": "Eager",
                                                            "type": "object",
                                                            "properties":
                                                            {
                                                                "policy":
                                                                {
                                                                    "title": "Policy",
                                                                    "enum": [ "none", "all", "explicit" ],
                                                                    "default": "none"
                                                                },
                                                                "match":
                                                                {
                                                                    "title": "Match",
                                                                    "type": "array",
                                                                    "items":
                                                                    {
                                                                        "type": "string"
                                                                    },
                                                                    "minItems": 1
                                                                }
                                                            },
                                                            "if":
                                                            {
                                                                "required": [ "policy" ],
                                                                "properties":
                                                                {
                                                                    "policy":
                                                                    {
                                                                        "const": "explicit"
                                                                    }
                                                                }
                                                            },
                                                            "then":
                                                            {
                                                                "required": [ "match" ]
                                                            },
                                                            "else":
                                                            {
                                                                "not": { "required": [ "match" ] }
                                                            },
                                                            "additionalProperties": false
                                                        }
                                                    },
                                                    "additionalProperties": false
                                                }
                                            },
                                            "required": [ "store" ],
                                            "additionalProperties": false
                                        },
                                        "tools":
                                        {
                                            "title": "Tools",
                                            "$ref": "#/$defs/models"
                                        }
                                    },
                                    "additionalProperties": false
                                },
                                "routes":
                                {
                                    "title": "Routes",
                                    "type": "array",
                                    "items":
                                    {
                                        "type": "object",
                                        "properties":
                                        {
                                            "when":
                                            {
                                                "title": "When",
                                                "type": "array",
                                                "items":
                                                {
                                                    "type": "object",
                                                    "properties":
                                                    {
                                                        "toolkit":
                                                        {
                                                            "title": "Toolkit",
                                                            "type": "string"
                                                        },
                                                        "tools":
                                                        {
                                                            "title": "Tools",
                                                            "type": "array",
                                                            "items":
                                                            {
                                                                "type": "string"
                                                            }
                                                        },
                                                        "prompts":
                                                        {
                                                            "title": "Prompts",
                                                            "type": "array",
                                                            "items":
                                                            {
                                                                "type": "string"
                                                            }
                                                        },
                                                        "resources":
                                                        {
                                                            "title": "Resources",
                                                            "type": "array",
                                                            "items":
                                                            {
                                                                "type": "string"
                                                            }
                                                        }
                                                    },
                                                    "required": [ "toolkit" ],
                                                    "additionalProperties": false
                                                }
                                            },
                                            "with":
                                            {
                                                "title": "With",
                                                "type": "object",
                                                "properties":
                                                {
                                                    "cache":
                                                    {
                                                        "title": "Cache",
                                                        "type": "object",
                                                        "properties":
                                                        {
                                                            "credentials":
                                                            {
                                                                "title": "Credentials",
                                                                "type": "string"
                                                            }
                                                        },
                                                        "additionalProperties": false
                                                    }
                                                },
                                                "additionalProperties": false
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                ]
            }
        }
    },
    {
        "op": "add",
        "path": "/$defs/binding-ext/mcp",
        "value":
        {
            "indexes":
            {
                "type": "object",
                "properties":
                {
                    "type":
                    {
                        "title": "Type",
                        "type": "string",
                        "enum": [ "keyword" ]
                    }
                },
                "required": [ "type" ],
                "allOf":
                [
                    {
                        "if":
                        {
                            "properties":
                            {
                                "type":
                                {
                                    "const": "keyword"
                                }
                            }
                        },
                        "then":
                        {
                            "properties":
                            {
                                "type":
                                {
                                    "const": "keyword"
                                }
                            },
                            "additionalProperties": false
                        }
                    }
                ],
                "flat":
                {
                    "title": "Type",
                    "type": "string",
                    "enum": [ "keyword" ]
                }
            }
        }
    }
]
